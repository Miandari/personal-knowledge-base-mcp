# ──────────────────────────────────────────────
# compiled-knowledge-base — API keys
# Copy this to .env and fill in your keys.
# .env is gitignored — never commit real secrets.
#
# All non-secret config lives in tests/config.py (checked in).
# Per-run overrides use pytest CLI flags: --live-vault, --judge-provider, --judge-model.
# ──────────────────────────────────────────────

# Anthropic (required for LLM-judge tests)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (optional — use with --judge-provider openai)
OPENAI_API_KEY=sk-...

# Google (optional — use with --judge-provider google)
GOOGLE_API_KEY=...

# OpenRouter (optional — use with --judge-provider openrouter)
OPENROUTER_API_KEY=sk-or-...

# ──────────────────────────────────────────────
# KB server config
# ──────────────────────────────────────────────

# Embedding provider API key (required for vector search)
# VOYAGE_API_KEY=your-voyage-api-key

# Optional: Bearer token for remote MCP access (HTTP transport only)
# Has no effect in stdio mode. Use --no-auth to disable even when set.
# KB_MCP_TOKEN=

# Optional: override embedding provider ("voyage" or "noop")
# KB_EMBEDDING_PROVIDER=voyage