# ──────────────────────────────────────────────
# compiled-knowledge-base — environment variables
# Copy this to .env and fill in your keys.
# .env is gitignored — never commit real secrets.
# ──────────────────────────────────────────────

# ── LLM providers (test suite + future scripted use) ─────────────────

# Anthropic (required — primary judge, primary ingestion LLM)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (optional — secondary judge for cross-check)
OPENAI_API_KEY=sk-...

# Google (optional — tertiary judge)
GOOGLE_API_KEY=...

# OpenRouter (optional — multi-model access through one key)
OPENROUTER_API_KEY=sk-or-...

# ── Test suite configuration ─────────────────────────────────────────

# Vault path (default: the directory containing this file)
TEST_VAULT_PATH=/Users/mk/Work/compiled-knowledge-base

# qmd collection name (must match what you registered with qmd collection add)
TEST_QMD_COLLECTION=kb

# Run tests against the live vault (true) or a sandbox copy (false)?
# Default: false (safe for development). Set true for Phase 3 live integration tests.
TEST_USE_LIVE_VAULT=false

# ── Judge configuration ──────────────────────────────────────────────

# Which provider to use for LLM-as-judge? (anthropic | openai | google | openrouter)
TEST_JUDGE_PROVIDER=anthropic

# Which model to use for judging? (defaults below if blank)
# anthropic: claude-sonnet-4-20250514
# openai: gpt-4.1
# google: gemini-2.5-pro
# openrouter: anthropic/claude-sonnet-4 (or any model slug)
TEST_JUDGE_MODEL=
